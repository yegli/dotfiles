#!/bin/bash
set -e

section() { echo; echo "==> $1"; }
ok()      { echo "    [done] $1"; }
skip()    { echo "    [skip] $1"; }
info()    { echo "    --> $1"; }

section "SSH Key Generation"

SSH_DIR="$HOME/.ssh"
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"
info "SSH directory: $SSH_DIR"

generate_key() {
    local name="$1"
    local email="$2"
    local keyfile="$SSH_DIR/id_ed25519_${name}"

    if [[ -f "$keyfile" ]]; then
        skip "Key for ${name} already exists: ${keyfile}"
        return
    fi

    info "Generating ed25519 key for ${name} (${email})..."
    ssh-keygen -t ed25519 -C "$email" -f "$keyfile" -N ""
    ok "Key generated: $keyfile"
    echo
    echo "    Public key for ${name} — add this to GitHub/GitLab:"
    echo "    $(cat "${keyfile}.pub")"
    echo
}

generate_key "private" "{{ .email_private }}"
generate_key "ost"     "{{ .email_ost }}"
generate_key "work"    "{{ .email_work }}"

# Write SSH config
SSH_CONFIG="$SSH_DIR/config"

if ! grep -q "id_ed25519_private" "$SSH_CONFIG" 2>/dev/null; then
    cat >> "$SSH_CONFIG" <<'EOF'

# Private
Host github-private
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_private

# OST
Host github-ost
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_ost

# Work
Host github-work
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_work
EOF
    chmod 600 "$SSH_CONFIG"
fi

echo "SSH setup complete. Add the public keys above to their respective accounts before cloning repos."
