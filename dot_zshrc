export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="robbyrussell"

plugins=(
    git
    z
    macos
    brew
    zsh-autosuggestions
    zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# Editor
export EDITOR="code --wait"

# Path
export PATH="$HOME/.local/bin:$PATH"

# Aliases
alias ll="ls -lAh"
alias ..="cd .."
alias ...="cd ../.."
alias gs="git status"
alias gp="git pull"
alias gpu="git push"
alias K="kubectl"

# Code folders
alias priv="cd ~/_code/private"
alias ost="cd ~/_code/ost"
alias work="cd ~/_code/work"

# Homebrew
eval "$(/opt/homebrew/bin/brew shellenv)"

